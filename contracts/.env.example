# Sepolia: copy to .env and fill in (never commit .env)
#
# Private key for the wallet that pays deployment gas (0x + 64 hex chars).
# Must be the key for the account you want — e.g. if your address is
# 0xFA8AbBed5eb78f92CB1DA6ec8D2658e6100419EE, import that account in MetaMask
# and export the private key from MetaMask (Settings → Security → Show private key).
# SEPOLIA_PRIVATE_KEY=0x................................

# Optional: Alchemy / Infura / PublicNode (default is a public Sepolia RPC)
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
