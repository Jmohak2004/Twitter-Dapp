# Deployed DecentralizedTwitter address (0x…)
# VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: backend that serves GET /api/contract with { "address": "0x…" }
# Leave unset in dev to use Vite proxy to port 5000
# VITE_API_URL=http://127.0.0.1:5000

# RPC endpoints (defaults work for local Hardhat + public Sepolia)
# VITE_HARDHAT_RPC=http://127.0.0.1:8545
# VITE_SEPOLIA_RPC=https://rpc.sepolia.org

# 31337 = Hardhat / Anvil. 11155111 = Sepolia (match your deployment)
# VITE_PREFERRED_CHAIN_ID=31337
