# --- Contract (required) ---
# VITE_CONTRACT_ADDRESS=0x…

# --- Network the UI asks your wallet to use (must match where the contract lives) ---
# Local Hardhat (default if unset)
# VITE_PREFERRED_CHAIN_ID=31337
# Sepolia testnet
# VITE_PREFERRED_CHAIN_ID=11155111

# Optional RPC overrides
# VITE_HARDHAT_RPC=http://127.0.0.1:8545
# VITE_SEPOLIA_RPC=https://rpc.sepolia.org

# Optional: custom API base for /api/contract (otherwise Vite proxies to :5001 in dev)
# VITE_API_URL=http://127.0.0.1:5001
